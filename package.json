{
  "name": "quakelite",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "start": "npm run start -w server",
    "typecheck": "tsc -p client --noEmit && tsc -p server --noEmit",
    "test": "tsx tests/movement.test.ts && tsx tests/protocol.test.ts && tsx tests/map.test.ts",
    "tunnel": "cloudflared tunnel --url http://localhost:5173",
    "tunnel:prod": "cloudflared tunnel --url http://localhost:3001"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
