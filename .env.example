# Discord application credentials — create an app at https://discord.com/developers/applications
# VITE_DISCORD_CLIENT_ID is exposed to the client; DISCORD_CLIENT_SECRET must stay server-side only.
VITE_DISCORD_CLIENT_ID=your_application_id_here
DISCORD_CLIENT_ID=your_application_id_here
DISCORD_CLIENT_SECRET=your_oauth2_client_secret_here

# Game server port (the Express + WebSocket server)
PORT=3001
